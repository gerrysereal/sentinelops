+            </CardContent>
+          </Card>
+        </section>
+      ) : null}
+    </div>
+  );
+}
+
+function Field({ label, value, onChange, placeholder, type = 'text' }: { label: string; value: string; onChange: (value: string) => void; placeholder?: string; type?: string }) {
