POSTGRES_DB=sentinelops
POSTGRES_USER=sentinelops
POSTGRES_PASSWORD=change-me-local-only
DATABASE_URL=postgres://sentinelops:change-me-local-only@postgres:5432/sentinelops?sslmode=disable
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
API_PORT=8080
APP_ENV=local
AUTH_ENABLED=false
SENTINELOPS_BOOTSTRAP_TOKEN=
KEYCLOAK_ISSUER_URL=
KEYCLOAK_CLIENT_ID=sentinelops-web
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api/v1
PLATFORM_MODE=demo
INTEGRATION_ENCRYPTION_KEY=change-me-to-a-long-random-secret
REQUEST_TIMEOUT=15s
INTEGRATION_TIMEOUT=8s
INTEGRATION_RETRIES=2
LOG_FORMAT=text

# OpenTelemetry application instrumentation. Keep disabled for local Docker
# unless the collector endpoint is reachable from the API container.
OTEL_SDK_DISABLED=true
OTEL_SERVICE_NAME=sentinelops-api
OTEL_SERVICE_VERSION=otel-opentelemetry-collector.monitoring.svc.cluster.local:43170.1.0
OTEL_DEPLOYMENT_ENVIRONMENT=local
OTEL_EXPORTER_OTLP_ENDPOINT=172.17.0.1:4317
OTEL_EXPORTER_OTLP_INSECURE=true
OTEL_EXPORTER_OTLP_TIMEOUT=10s
OTEL_BSP_SCHEDULE_DELAY=5s
OTEL_METRIC_EXPORT_INTERVAL=30s
OTEL_TRACES_SAMPLER=parentbased_always_on
OTEL_TRACES_SAMPLER_ARG=1
