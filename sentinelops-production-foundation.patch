+		}
+	}
+	status := http.StatusOK
+	state := "ready"
+	if !ready {
+		status = http.StatusServiceUnavailable
+		state = "degraded"
+	}
+	c.JSON(status, gin.H{"status": state, "checks": checks, "checkedAt": time.Now().UTC()})
